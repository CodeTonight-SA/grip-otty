{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Otty Pad Studio",
  "version": "0.1.0",
  "identifier": "za.codetonight.otty-pad-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Otty Pad Studio",
        "width": 1240,
        "height": 820,
        "minWidth": 640,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
